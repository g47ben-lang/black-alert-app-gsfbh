# מקור האירועים (כרגע הפיד הציבורי; בעתיד אפשר להחליף ל-API/DB משלכם)
SOURCE_URL=https://black-alert.com
POLL_MS=5000

# --- FCM (למכשירים עם Google Play) ---
# הורידו service-account JSON מ-Firebase Console → Project settings → Service accounts.
# הצביעו אליו (path בתוך הקונטיינר). ללא זה — FCM כבוי.
GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-service-account.json
FCM_TOPIC=alerts

# --- MQTT (למכשירים ללא Google Play) ---
# ב-compose המקומי: mqtt://mosquitto:1883 . בענן: ssl://your-broker:8883
MQTT_URL=mqtt://mosquitto:1883
MQTT_TOPIC=alerts
MQTT_USERNAME=
MQTT_PASSWORD=

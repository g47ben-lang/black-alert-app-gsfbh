<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="32dp">

        <!-- ===== סינון ===== -->
        <TextView style="@style/SectionHeader" android:text="סינון התראות" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_2"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectCities"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/set_select_cities"
                    app:cornerRadius="10dp" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginVertical="12dp" android:background="@color/surface_3" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/set_event_types"
                    android:textColor="@color/on_surface_var"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/eventTypesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginVertical="12dp" android:background="@color/surface_3" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchSilentNotSelected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/set_silent_not_selected" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== קרבה ===== -->
        <TextView style="@style/SectionHeader" android:text="סינון לפי מיקום" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_2"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchProximity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/set_proximity" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="מציג התראות רק אם האירוע קרוב אליך"
                    android:textColor="@color/on_surface_var"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchProximityTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="לפי זמן נסיעה (במקום מרחק)" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="מרחק (ק״מ)" android:textColor="@color/on_surface_var" android:textSize="12sp" />
                        <EditText android:id="@+id/proximityRadius" android:layout_width="80dp"
                            android:layout_height="wrap_content" android:inputType="number"
                            android:background="@color/surface_3" android:padding="8dp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="זמן (דקות)" android:textColor="@color/on_surface_var" android:textSize="12sp" />
                        <EditText android:id="@+id/proximityTime" android:layout_width="80dp"
                            android:layout_height="wrap_content" android:inputType="number"
                            android:background="@color/surface_3" android:padding="8dp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveProximity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="שמור"
                        app:cornerRadius="8dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== צליל ===== -->
        <TextView style="@style/SectionHeader" android:text="@string/set_sound" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_2"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <Spinner
                    android:id="@+id/soundSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@color/surface_3"
                    android:padding="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickSound"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="➕ צליל מהמכשיר"
                    app:cornerRadius="8dp" />

                <TextView
                    android:id="@+id/customSoundLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:layout_marginTop="6dp"
                    android:visibility="gone" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginVertical="12dp" android:background="@color/surface_3" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchVibrate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/set_vibrate" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchVibrateOnly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="רטט בלבד (ללא צליל)" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchDnd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="צלצל גם במצב 'נא לא להפריע'" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== תצוגה ===== -->
        <TextView style="@style/SectionHeader" android:text="תצוגת התראה" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_2"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchFullscreen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/set_fullscreen" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="פותח מסך מלא ומדליק את המסך גם כשנעול"
                    android:textColor="@color/on_surface_var"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="14dp"
                    android:background="@color/surface" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchForceFullscreen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/set_force_fullscreen" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/set_force_fullscreen_desc"
                    android:textColor="@color/on_surface_var"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="14dp"
                    android:background="@color/surface" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchMapInNotification"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/set_map_in_notification" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="תמונת מפה של מוקד האירוע בתוך באנר ההתראה (דורש רשת)"
                    android:textColor="@color/on_surface_var"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== שעות שקטות ===== -->
        <TextView style="@style/SectionHeader" android:text="@string/set_quiet" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_2"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchQuiet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/set_quiet" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/set_quiet_from" android:textColor="@color/on_surface_var" />
                    <EditText android:id="@+id/quietFrom" android:layout_width="80dp"
                        android:layout_height="wrap_content" android:inputType="time" android:text="23:00"
                        android:layout_marginStart="8dp" android:background="@color/surface_3" android:padding="8dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/set_quiet_to" android:textColor="@color/on_surface_var"
                        android:layout_marginStart="16dp" />
                    <EditText android:id="@+id/quietTo" android:layout_width="80dp"
                        android:layout_height="wrap_content" android:inputType="time" android:text="07:00"
                        android:layout_marginStart="8dp" android:background="@color/surface_3" android:padding="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveQuiet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/set_save"
                        app:cornerRadius="8dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== היסטוריה ===== -->
        <TextView style="@style/SectionHeader" android:text="היסטוריה" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_2"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchLocalHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/set_local_history" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== מסירה ותדירות — תמיד גלוי ===== -->
        <LinearLayout
            android:id="@+id/advancedSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView style="@style/SectionHeader" android:text="מסירה ותדירות" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_2"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="אופן קבלת התראות"
                        android:textColor="@color/on_surface_var"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/deliverySpinner"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@color/surface_3"
                        android:padding="8dp" />

                    <TextView
                        android:id="@+id/deliveryStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="13sp"
                        android:textColor="@color/primary" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginVertical="12dp" android:background="@color/surface_3" />

                    <!-- שדות תדירות — גלויים רק במצב עצמאי -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="בדיקה — מסך דולק (שנ')" android:textColor="@color/on_surface_var" android:textSize="12sp" />
                            <EditText android:id="@+id/pollOn" android:layout_width="match_parent"
                                android:layout_height="wrap_content" android:inputType="number"
                                android:background="@color/surface_3" android:padding="8dp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="בדיקה — מסך כבוי (שנ')" android:textColor="@color/on_surface_var" android:textSize="12sp" />
                            <EditText android:id="@+id/pollOff" android:layout_width="match_parent"
                                android:layout_height="wrap_content" android:inputType="number"
                                android:background="@color/surface_3" android:padding="8dp" />
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="גיבוי בFirebase (דק', 0=כבוי)" android:textColor="@color/on_surface_var" android:textSize="12sp" />
                            <EditText android:id="@+id/safetyPoll" android:layout_width="match_parent"
                                android:layout_height="wrap_content" android:inputType="number"
                                android:background="@color/surface_3" android:padding="8dp" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveDelivery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="@string/set_save"
                            app:cornerRadius="8dp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- מקור נתונים -->
            <TextView style="@style/SectionHeader" android:text="מתקדם — מקור נתונים" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_2"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="במכשיר מסונן (NetFree) — הפנה ל-proxy שמשקף את black-alert.com"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_var"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/sourceUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="https://black-alert.com"
                        android:inputType="textUri"
                        android:textDirection="ltr"
                        android:background="@color/surface_3"
                        android:padding="10dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveSource"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/set_save"
                        app:cornerRadius="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- MQTT -->
            <TextView style="@style/SectionHeader" android:text="מתקדם — MQTT" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_2"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="push למכשירים ללא Google — כתובת broker (ריק = כבוי)"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_var"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/mqttBroker"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="ssl://broker:8883"
                        android:inputType="textUri"
                        android:textDirection="ltr"
                        android:background="@color/surface_3"
                        android:padding="10dp" />

                    <EditText
                        android:id="@+id/mqttTopic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="alerts"
                        android:inputType="text"
                        android:textDirection="ltr"
                        android:background="@color/surface_3"
                        android:padding="10dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveMqtt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/set_save"
                        app:cornerRadius="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
        <!-- /advancedSection -->

    </LinearLayout>
</ScrollView>

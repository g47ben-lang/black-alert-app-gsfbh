<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/logo"
                    android:contentDescription="@string/app_name" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textColor="@color/primary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.03" />

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface_var"
                        android:textSize="13sp"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchService"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- קו הפרדה צהוב -->
            <View
                android:layout_width="48dp"
                android:layout_height="3dp"
                android:layout_marginTop="18dp"
                android:background="@color/primary" />

        </LinearLayout>

        <!-- כפתורי חיוג -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCallExtradition"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:backgroundTint="#FFD32F2F"
                android:textColor="@color/white"
                android:textSize="19sp"
                android:textStyle="bold"
                android:text="דיווח על הסגרה"
                android:letterSpacing="0.01"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_call"
                app:iconTint="@color/white"
                app:iconGravity="textEnd"
                app:iconSize="22dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEmergencyContacts"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/surface_2"
                android:textColor="@color/primary"
                android:textSize="15sp"
                android:text="קווי חירום וארגוני סיוע"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                app:cornerRadius="14dp" />

        </LinearLayout>

        <!-- כותרת התראות -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="10dp">

            <View
                android:layout_width="4dp"
                android:layout_height="18dp"
                android:background="@color/primary"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="התראות נוכחיות"
                android:textColor="@color/on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistory"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="היסטוריה מלאה"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <!-- כרטיסי התראות -->
        <LinearLayout
            android:id="@+id/recentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp" />

        <!-- כפתור הגדרות -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="28dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/surface_2"
                android:layout_marginBottom="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/main_settings"
                app:cornerRadius="14dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>

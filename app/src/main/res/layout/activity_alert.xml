<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:layoutDirection="rtl">

    <!-- ראש: לוגו + סוג אירוע + מיקום -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:padding="16dp">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/logo"
            android:contentDescription="@string/app_name" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/alertTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/alertCities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="@color/on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/alertAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_var"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- הערת החמ"ל -->
    <TextView
        android:id="@+id/alertNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/note_bg"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        android:textColor="@color/on_surface"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.4" />

    <!-- זמני הגעה ממיקום המשתמש (נסיעה גדול; הליכה/אופניים קטן) -->
    <LinearLayout
        android:id="@+id/travelPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/travelMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/travelSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/on_surface_var"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- מפה (נוצרת ב-runtime בתוך מיכל זה — עמיד בכשל אם אין WebView במכשיר) -->
    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:background="@color/surface">

        <TextView
            android:id="@+id/mapFallback"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="16dp"
            android:textColor="@color/on_surface_var"
            android:textSize="15sp"
            android:visibility="gone" />
    </FrameLayout>

    <!-- כפתורים -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingTop="0dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNavigate"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="@color/primary"
            android:text="נווט עכשיו"
            android:textColor="@color/on_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_navigate"
            app:iconTint="@color/on_primary"
            app:iconGravity="textStart"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnArrived"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF388E3C"
            android:text="הגעתי לזירה"
            android:textColor="#FFFFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClose"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="@string/action_close"
            android:textColor="@color/on_surface"
            android:textSize="17sp" />
    </LinearLayout>

</LinearLayout>
